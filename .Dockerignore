# Python byte‑compiled files
__pycache__/
*.py[cod]
*$py.class

# Django migrations (if you don’t want to bake them into the image)
**/migrations/

# Environment files & virtualenvs
.env
venv/
.venv/
ENV/
env/

# Docker files (you don’t need to COPY these into the image)
Dockerfile
docker-compose.yml

# Build artifacts
build/
dist/
*.egg-info/

# Staticfiles collected (if you run collectstatic locally)
staticfiles/

# Git & VCS
.git
.gitignore

# IDE/editor temp files
*.swp
*~
.vscode/
.idea/

# macOS / OS temp files
.DS_Store